#!/bin/sh
# Post-install hook for aria2-next-static.
#
# Mirrors the USERID:=aria2=6800:aria2=6800 directive used by the official
# OpenWrt aria2 package (net/aria2/Makefile). The init script can then run
# the daemon as the unprivileged 'aria2' user when configured to do so.
#
# Idempotent: safe to run on upgrade and re-install.

[ -n "${IPKG_INSTROOT-}" ] && exit 0

ARIA2_UID=6800
ARIA2_GID=6800
ARIA2_USER=aria2
ARIA2_GROUP=aria2

add_group() {
    if ! grep -q "^${ARIA2_GROUP}:" /etc/group 2>/dev/null; then
        echo "${ARIA2_GROUP}:x:${ARIA2_GID}:" >> /etc/group
    fi
}

add_user() {
    if ! grep -q "^${ARIA2_USER}:" /etc/passwd 2>/dev/null; then
        echo "${ARIA2_USER}:x:${ARIA2_UID}:${ARIA2_GID}:aria2:/var/lib/aria2:/bin/false" >> /etc/passwd
        echo "${ARIA2_USER}:x:0:0:99999:7:::" >> /etc/shadow 2>/dev/null || true
    fi
}

add_group
add_user

# Enable but do not start the service. The user must configure
# /etc/config/aria2-next (set 'enabled 1' and a download 'dir') first.
if [ -x /etc/init.d/aria2-next ]; then
    /etc/init.d/aria2-next enable >/dev/null 2>&1 || true
fi

exit 0
